<!doctype html>
<html class="no-js" lang="{{ request.locale.iso_code }}">
  <head>
    <meta charset="utf-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <link rel="canonical" href="{{ canonical_url }}">

    <title>{{ page_title }}</title>

    {% if page_description %}
      <meta name="description" content="{{ page_description | escape }}">
    {% endif %}

    {{ content_for_header }}

    {%- style -%}
      :root {
        --font-heading: serif;
        --font-body: sans-serif;
        --color-bg: {{ settings.color_bg | default: '#FAF8F5' }};
        --color-text: {{ settings.color_text | default: '#1A1A1A' }};
        --color-accent: {{ settings.color_accent | default: '#C5A880' }};
        --fluid-spacing-lg: clamp(4rem, 8vw, 12rem);
        --fluid-spacing-md: clamp(2rem, 4vw, 6rem);
      }

      body {
        margin: 0;
        font-family: var(--font-body);
        background-color: var(--color-bg);
        color: var(--color-text);
        -webkit-font-smoothing: antialiased;
        overflow-x: hidden;
      }
      .visually-hidden {
        position: absolute !important;
        overflow: hidden;
        width: 1px;
        height: 1px;
        margin: -1px;
        padding: 0;
        border: 0;
        clip: rect(0 0 0 0);
      }
    {%- endstyle -%}
    
    {{ 'theme.css' | asset_url | stylesheet_tag }}
    <script src="{{ 'theme.js' | asset_url }}" defer></script>
  </head>

  <body>
    <main id="MainContent" role="main" tabindex="-1">
      {{ content_for_layout }}
    </main>
    <div id="screen-reader-announce" class="visually-hidden" aria-live="polite"></div>
  </body>
</html>
