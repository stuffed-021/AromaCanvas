<section class="hero-banner">
  <div class="hero-content">
    <h1 class="editorial-title">{{ section.settings.heading }}</h1>
    <p>{{ section.settings.subheading }}</p>
  </div>
</section>

{% schema %}
{
  "name": "Cinematic Hero",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "AromaCanvas Studio"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Where sensory poetry meets raw elemental materials."
    }
  ],
  "presets": [
    {
      "name": "Cinematic Hero"
    }
  ]
}
{% endschema %}
